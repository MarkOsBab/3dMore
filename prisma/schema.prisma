generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  isActive  Boolean   @default(true)
  sortOrder Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  products  Product[]
}

model Product {
  id          String    @id @default(cuid())
  name        String
  description String
  price       Float
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  isActive    Boolean   @default(true)
  isFeatured  Boolean   @default(false)
  isOffer     Boolean   @default(false)
  discountPct Float?    @default(0)
  thumbnail   String?
  // 3D viewer initial camera (spherical coords around the model)
  viewerYaw     Float     @default(0)    // radians, rotation around Y
  viewerPitch   Float     @default(0)    // radians, elevation (0 = frontal)
  viewerZoom    Float     @default(3)    // camera distance to target
  viewerTargetX Float     @default(0)    // camera look-at X
  viewerTargetY Float     @default(0)    // camera look-at Y
  viewerTargetZ Float     @default(0)    // camera look-at Z
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  variants ProductVariant[]
  parts    ProductPart[]

  @@index([categoryId])
}

model ProductVariant {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  colorName   String
  imageUrl    String
  price       Float?
  isOffer     Boolean  @default(false)
  discountPct Float?   @default(0)
  partColors  Json?    // { [partId]: colorId } when the product has 3D parts
  createdAt   DateTime @default(now())
}

model Color {
  id         String        @id @default(cuid())
  name       String        @unique
  hex        String        // "#7c3aed"
  isActive   Boolean       @default(true)
  sortOrder  Int           @default(0)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  defaultFor ProductPart[]
}

model ProductPart {
  id             String   @id @default(cuid())
  productId      String
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name           String
  modelUrl       String
  format         String   // "stl" | "glb" | "gltf"
  positionX      Float    @default(0)
  positionY      Float    @default(0)
  positionZ      Float    @default(0)
  rotationX      Float    @default(0)
  rotationY      Float    @default(0)
  rotationZ      Float    @default(0)
  scale          Float    @default(1)
  defaultColorId String?
  defaultColor   Color?   @relation(fields: [defaultColorId], references: [id], onDelete: SetNull)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([productId])
}

model PromoCode {
  id          String    @id @default(cuid())
  code        String    @unique
  discountPct Float
  validUntil  DateTime?
  usageLimit  Int?      @default(100)
  timesUsed   Int       @default(0)
  isActive    Boolean   @default(true)
  userId      String?   // si no-null, solo ese user puede usarlo
  createdAt   DateTime  @default(now())

  @@index([userId])
}

model UserProfile {
  id         String         @id // supabase auth user id
  email      String?
  firstName  String?
  lastName   String?
  documentId String?
  phone      String?
  avatarUrl  String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  addresses  SavedAddress[]
}

model SavedAddress {
  id           String      @id @default(cuid())
  userId       String
  user         UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  label        String?
  street       String
  doorNumber   String
  corner       String?
  neighborhood String
  postalCode   String?
  zoneId       String
  zoneName     String
  isDefault    Boolean     @default(false)
  createdAt    DateTime    @default(now())

  @@index([userId])
}

model ShippingZone {
  id                String   @id @default(cuid())
  name              String   @unique
  cost              Float
  isActive          Boolean  @default(true)
  sortOrder         Int      @default(0)
  isMeetingPoint    Boolean? // null = fallback por costo (≤ $100)
  meetingPointName  String?  // ej: "Plaza del Prado"
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Order {
  id                 String         @id @default(cuid())
  mpPaymentId        String?        @unique
  mpExternalRef      String         @unique
  status             OrderStatus    @default(PENDING)
  items              Json           // Array de CartItem serializado
  subtotal           Float
  total              Float
  promoCode          String?
  promoDiscount      Float          @default(0)
  payerEmail         String?
  payerName          String?
  userId             String?
  shippingMethod     ShippingMethod @default(PICKUP)
  shippingCost       Float          @default(0)
  shippingData       Json?          // { zoneId?, zoneName?, address?, agency?, notes? }
  trackingCode       String?        // Código de seguimiento (DAC u otra logística)
  trackingCarrier    String?        // Empresa de logística (ej: "DAC", "Correo Uruguayo")
  customerFirstName  String?
  customerLastName   String?
  customerDocument   String?
  customerPhone      String?
  customerEmail      String?
  loyaltyPromoIssued Boolean        @default(false)
  reviewRating       Int?
  reviewText         String?
  reviewImageUrl     String?
  reviewShowImage    Boolean        @default(false)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  statusHistory      OrderStatusHistory[]

  @@index([userId])
}

model OrderStatusHistory {
  id        String      @id @default(cuid())
  orderId   String
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status    OrderStatus
  createdAt DateTime    @default(now())

  @@index([orderId])
}

enum OrderStatus {
  PENDING
  APPROVED
  CONFIRMED
  READY_FOR_DELIVERY
  DELIVERED
  REJECTED
  CANCELLED
}

enum ShippingMethod {
  HOME_MVD       // legacy — alias de MEETING_POINT (mantenido para pedidos antiguos)
  MEETING_POINT  // entrega en un punto de encuentro público (zona seleccionada)
  HOME_DELIVERY  // entrega a domicilio dentro de una zona-punto-de-encuentro elegible
  AGENCY
  PICKUP
}
