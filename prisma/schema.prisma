generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String
  price       Float
  category    String
  isActive    Boolean  @default(true)
  isOffer     Boolean  @default(false)
  discountPct Float?   @default(0)
  thumbnail   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  variants ProductVariant[]
}

model ProductVariant {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  colorName   String
  imageUrl    String
  price       Float?
  isOffer     Boolean  @default(false)
  discountPct Float?   @default(0)
  createdAt   DateTime @default(now())
}

model PromoCode {
  id          String    @id @default(cuid())
  code        String    @unique
  discountPct Float
  validUntil  DateTime?
  usageLimit  Int?      @default(100)
  timesUsed   Int       @default(0)
  isActive    Boolean   @default(true)
  userId      String?   // si no-null, solo ese user puede usarlo
  createdAt   DateTime  @default(now())

  @@index([userId])
}

model UserProfile {
  id         String   @id // supabase auth user id
  email      String?
  firstName  String?
  lastName   String?
  documentId String?
  phone      String?
  avatarUrl  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ShippingZone {
  id        String   @id @default(cuid())
  name      String   @unique
  cost      Float
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id                 String         @id @default(cuid())
  mpPaymentId        String?        @unique
  mpExternalRef      String         @unique
  status             OrderStatus    @default(PENDING)
  items              Json           // Array de CartItem serializado
  subtotal           Float
  total              Float
  promoCode          String?
  promoDiscount      Float          @default(0)
  payerEmail         String?
  payerName          String?
  userId             String?
  shippingMethod     ShippingMethod @default(PICKUP)
  shippingCost       Float          @default(0)
  shippingData       Json?          // { zoneId?, zoneName?, address?, agency?, notes? }
  customerFirstName  String?
  customerLastName   String?
  customerDocument   String?
  customerPhone      String?
  customerEmail      String?
  loyaltyPromoIssued Boolean        @default(false)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([userId])
}

enum OrderStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum ShippingMethod {
  HOME_MVD
  AGENCY
  PICKUP
}
